# Generated by Home Manager.
unmailboxes *

set ssl_force_tls = yes
# set certificate_file=/etc/ssl/certs/ca-certificates.crt

# GPG section
set crypt_autosign = no
set crypt_opportunistic_encrypt = no
set pgp_use_gpg_agent = yes
set mbox_type = Maildir
set sort = "threads"

# MTA section
set sendmail='msmtp -a peasec'

set mail_check_stats
set mail_check_stats_interval = 60


# Sidebar
set sidebar_visible = yes
set sidebar_short_path = yes
set sidebar_width = 20
set sidebar_format = '%D%* %?N?%N/?%S'


# MRA section
set folder='/Users/pkuehn/var/mail/peasec'
set from='kuehn@peasec.tu-darmstadt.de'
set postponed='+Entwürfe'
set realname='Philipp Kühn'
set record='+Gesendete Elemente'
set spoolfile='+Inbox'
set trash='+Gelöschte Elemente'


# Extra configuration
color indicator    #F7768E  black
color status       #F7768E  default

color sidebar_highlight #F7768E default

named-mailboxes "peasec"    "+Inbox"
named-mailboxes " archiv"   "+Archiv"
named-mailboxes " archive"  "+Archive"
named-mailboxes " sent"     "+Gesendete Elemente"
named-mailboxes " drafts"   "+Entwürfe"
named-mailboxes " junk"     "+Junk-E-Mail"
named-mailboxes " trash"    "+Gelöschte Elemente"

macro index e      ":set confirmappend=no delete=yes auto_tag=yes\n<save-message>+Archiv\n<sync-mailbox>:set confirmappend=yes delete=yes\n"


set signature = ~/.config/neomutt/signatures/peasec-signature

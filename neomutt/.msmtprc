# Set default values for all following accounts.
defaults
auth           on
tls            on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile        ~/.msmtp.log

# Audacis
account        audacis
host           mail.your-server.de
port           465
tls_starttls   off
from           philipp@audacis.net
user           philipp@audacis.net
passwordeval   "cat ~/Documents/misc/mail.audacis.net"

# Audacis
account        sink
host           mail.your-server.de
port           465
tls_starttls   off
from           sink@audacis.net
user           sink@audacis.net
passwordeval   "cat ~/Documents/misc/sink.audacis.net"

# PEASEC
account        peasec
host           smtp.tu-darmstadt.de
port           465
tls_starttls   off
from           kuehn@peasec.tu-darmstadt.de
user           ba01viny
passwordeval   "cat ~/Documents/misc/ba01viny"

# Set a default account
account default : audacis
